<script>
(function() {
    // Tab Switching
    const navItems = document.querySelectorAll('.ep-nav-item');
    const sections = document.querySelectorAll('.ep-section');

    navItems.forEach(item => {
        item.addEventListener('click', () => {
            const target = item.getAttribute('data-target');
            
            navItems.forEach(n => n.classList.remove('active'));
            sections.forEach(s => s.classList.remove('active'));
            
            item.classList.add('active');
            document.getElementById(target).classList.add('active');
            
            // Save active tab to localStorage
            localStorage.setItem('ep_active_tab', target);
        });
    });

    // Restore active tab
    const savedTab = localStorage.getItem('ep_active_tab');
    if (savedTab && document.getElementById(savedTab)) {
        const tabBtn = document.querySelector(`.ep-nav-item[data-target="${savedTab}"]`);
        if (tabBtn) tabBtn.click();
    }

    // Accordion for Source Details
    window.toggleEpDetails = function(key, event) {
        // Prevent toggle when clicking actions or switch
        if (event.target.closest('.ep-source-actions') || event.target.closest('.ep-switch')) return;
        
        const details = document.getElementById('details-' + key);
        const isOpening = !details.classList.contains('open');
        
        // Close others? (Optional, let's keep it simple for now)
        details.classList.toggle('open');
    };
})();
</script>

