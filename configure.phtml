<script>
function openTab(evt, tabName) {
    var i, content, tabs;
    content = document.getElementsByClassName("ep-content");
    for (i = 0; i < content.length; i++) { content[i].classList.remove("active"); }
    tabs = document.getElementsByClassName("ep-tab");
    for (i = 0; i < tabs.length; i++) { tabs[i].classList.remove("active"); }
    document.getElementById(tabName).classList.add("active");
    evt.currentTarget.classList.add("active");
}

function toggleDetails(key) {
    var el = document.getElementById('details-' + key);
    el.classList.toggle('open');
}
</script>

