$cronCmd = ($cfg['push_cron'] ?? '0 6 * * *') . ' php ' . escapeshellarg($cronScript) . ' --user=' . escapeshellarg(Minz_User::name());

// Load helper for history
require_once $ext->getPath() . '/FreshExtension_EinkPush_Helper.php';
$helper = new EinkPushHelper($this->getEpubDir(), 0, 0, 0, '');
$history = $helper->getHistory();
