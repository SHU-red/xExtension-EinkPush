<?php
/** @var EinkPush2Extension $this */
$cfg = $this->getConfig();
$categoryDAO = FreshRSS_Factory::createCategoryDao();
$categories = $categoryDAO->listCategories() ?: [];
$sources = $cfg['sources'] ?? [];

$favDefaults = ['enabled' => true, 'historyDays' => 0, 'unreadOnly' => true, 'markAsRead' => false, 'autoPush' => false, 'fetchContent' => true, 'addTimestamp' => false, 'maxArticles' => 0, 'removeFromFavorites' => false];
$catDefaults = ['enabled' => false, 'historyDays' => 7, 'unreadOnly' => true, 'markAsRead' => false, 'autoPush' => false, 'fetchContent' => true, 'addTimestamp' => false, 'maxArticles' => 0];

$ext = Minz_ExtensionManager::findExtension('EinkPush2');
$cronScript = $ext ? ($ext->getPath() . '/push_cron.php') : '';
$cronCmd = ($cfg['push_cron'] ?? '0 6 * * *') . ' php ' . escapeshellarg($cronScript) . ' --user=' . escapeshellarg(Minz_User::name());

// Load helper for history
require_once $ext->getPath() . '/FreshExtension_EinkPush_Helper.php';
$helper = new EinkPushHelper($this->getEpubDir(), 0, 0, 0, '');
$history = $helper->getHistory();

$cssUrl = $ext ? $ext->getFileUrl('style.css', 'css') : '';
$jsUrl = $ext ? $ext->getFileUrl('script.js', 'js') : '';
?>

<?php if ($cssUrl): ?>
<script>
(function() {
    var cssUrl = '<?= $cssUrl ?>';
    if (!document.querySelector('link[href^="' + cssUrl.split('?')[0] + '"]')) {
        var link = document.createElement('link');
        link.rel = 'stylesheet';
        link.type = 'text/css';
        link.href = cssUrl;
        document.head.appendChild(link);
    }
    
    var jsUrl = '<?= $jsUrl ?>';
    if (jsUrl && !document.querySelector('script[src^="' + jsUrl.split('?')[0] + '"]')) {
        var script = document.createElement('script');
        script.src = jsUrl;
        document.head.appendChild(script);
    }
})();
</script>
<?php endif; ?>

